DOCKER_IMAGE=acebench-openclaw:v1.0
GATEWAY_PORT=18789
TMP_WORKSPACE=/tmp_workspace
 
TASKS_SUBDIR=tasks
OUTPUT_SUBDIR=output
 
DEFAULT_MODEL=openrouter/stepfun/step-3.5-flash:free
 
DEFAULT_PARALLEL=1
 

# OpenRouter is used by default. You can also use any other OpenAI-compatible
# provider (e.g. DeepSeek, SiliconFlow): set OPENROUTER_BASE_URL to its endpoint
# (e.g. https://api.deepseek.com/v1) and put the corresponding key in OPENROUTER_API_KEY.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=


JUDGE_BASE_URL=https://openrouter.ai/api/v1
JUDGE_API_KEY=
JUDGE_MODEL=gpt-5.4-mini


# Using a Custom Model Endpoint
MY_PROXY_API_KEY=EMPTY

# Lobster profile env keys (add values here for skills that need them)
SEARCH_PROVIDER=  # serp, gemini, brave, serper
SERPER_API_KEY=xx
GEMINI_API_KEY=placeholder
BRAVE_API_KEY=placeholder
